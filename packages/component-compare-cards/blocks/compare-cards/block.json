{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "balefire/compare-cards",
  "title": "Compare Cards",
  "category": "balefire",
  "icon": "columns",
  "description": "Side-by-side A/B comparison cards (e.g. Authentic vs Counterfeit) with check/cross cells.",
  "keywords": [
    "compare",
    "versus",
    "authentic",
    "counterfeit",
    "balefire"
  ],
  "textdomain": "balefire",
  "version": "1.0.0",
  "render": "file:./render.php",
  "supports": {
    "anchor": true,
    "className": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "tone": {
      "type": "string",
      "default": "grey"
    },
    "eyebrow": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "leftLabel": {
      "type": "string",
      "default": "Authentic"
    },
    "rightLabel": {
      "type": "string",
      "default": "Counterfeit"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  },
  "editorScript": "balefire-compare-cards-editor"
}
