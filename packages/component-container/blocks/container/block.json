{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "balefire/container",
  "title": "Container",
  "category": "balefire",
  "icon": "align-wide",
  "description": "Max-width constrained, centered container with horizontal padding.",
  "keywords": [
    "container",
    "wrapper",
    "max-width",
    "center",
    "balefire"
  ],
  "textdomain": "balefire",
  "editorScript": "balefire-container-editor",
  "render": "file:./render.php",
  "supports": {
    "anchor": true,
    "className": true
  },
  "parent": [
    "balefire/section"
  ],
  "usesContext": [
    "balefire/sectionTone"
  ],
  "attributes": {
    "maxWidth": {
      "type": "string",
      "default": "wide"
    },
    "paddingInline": {
      "type": "string",
      "default": "md"
    }
  },
  "version": "1.0.0"
}
