{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "balefire/split-35-65",
  "title": "Split 35/65",
  "category": "balefire",
  "icon": "columns",
  "description": "A 35/65 two-column layout with text + button on the left (vertically centered) and image or video on the right.",
  "keywords": [
    "split",
    "columns",
    "35",
    "65",
    "layout",
    "image",
    "video",
    "balefire"
  ],
  "textdomain": "balefire",
  "editorScript": "balefire-split-35-65-editor",
  "render": "file:./render.php",
  "supports": {
    "anchor": true,
    "className": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "content": {
      "type": "string",
      "default": ""
    },
    "buttonLabel": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "mediaType": {
      "type": "string",
      "default": "image"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "gap": {
      "type": "string",
      "default": "8"
    },
    "reverse": {
      "type": "boolean",
      "default": false
    },
    "iconId": {
      "type": "number",
      "default": 0
    },
    "iconUrl": {
      "type": "string",
      "default": ""
    },
    "iconAlt": {
      "type": "string",
      "default": ""
    },
    "align": {
      "type": "string",
      "default": "wide"
    }
  },
  "version": "1.0.0"
}
