{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "balefire/logo-grid-item",
  "title": "Logo Grid Item",
  "category": "balefire",
  "icon": "format-image",
  "description": "A single logo image constrained to a uniform size for logo grid layouts.",
  "keywords": [
    "logo",
    "grid",
    "partner",
    "client",
    "balefire"
  ],
  "textdomain": "balefire",
  "editorScript": "balefire-logo-grid-item-editor",
  "render": "file:./render.php",
  "supports": {
    "anchor": true,
    "className": true
  },
  "attributes": {
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "linkType": {
      "type": "string",
      "default": "none"
    },
    "pageId": {
      "type": "number",
      "default": 0
    },
    "url": {
      "type": "string",
      "default": ""
    }
  },
  "version": "1.0.0"
}
